<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Swaply | Explorar</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        :root {
            --primary: #10b981;
            --primary-dark: #059669;
            --bg: #f8fafc;
            --white: #ffffff;
            --text-main: #1e293b;
            --text-muted: #64748b;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Plus Jakarta Sans', sans-serif;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            background-color: var(--bg);
            color: var(--text-main);
            overflow: hidden; /* Se habilita tras el splash */
        }

        /* --- SPLASH SCREEN --- */
        #splash-screen {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            z-index: 2000;
            transition: transform 0.8s cubic-bezier(0.77, 0, 0.175, 1);
        }

        .logo-box {
            width: 100px;
            height: 100px;
            background: var(--white);
            border-radius: 28px;
            display: flex;
            justify-content: center;
            align-items: center;
            box-shadow: 0 20px 40px rgba(0,0,0,0.15);
            animation: popIn 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .logo-box i {
            font-size: 50px;
            color: var(--primary);
        }

        .brand-name {
            margin-top: 20px;
            font-size: 2.5rem;
            font-weight: 800;
            color: var(--white);
            letter-spacing: -1px;
            opacity: 0;
            animation: fadeInUp 0.6s ease forwards 0.4s;
        }

        .loader {
            margin-top: 40px;
            width: 30px;
            height: 30px;
            border: 3px solid rgba(255,255,255,0.2);
            border-top: 3px solid var(--white);
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        /* --- CONTENIDO PRINCIPAL --- */
        #app-content {
            opacity: 0;
            transition: opacity 0.8s ease;
            max-width: 600px; /* Estilo tipo móvil/app */
            margin: 0 auto;
            background: var(--white);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        header {
            padding: 20px;
            position: sticky;
            top: 0;
            background: var(--white);
            z-index: 100;
        }

        .search-bar {
            background: #f1f5f9;
            padding: 12px 20px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            gap: 12px;
            margin-top: 15px;
        }

        .search-bar input {
            border: none;
            background: transparent;
            outline: none;
            width: 100%;
            font-size: 1rem;
        }

        .categories {
            display: flex;
            gap: 12px;
            overflow-x: auto;
            padding: 10px 20px;
            scrollbar-width: none;
        }

        .category-pill {
            padding: 8px 18px;
            background: #f1f5f9;
            border-radius: 20px;
            white-space: nowrap;
            font-size: 0.9rem;
            font-weight: 500;
            color: var(--text-muted);
            cursor: pointer;
        }

        .category-pill.active {
            background: var(--primary);
            color: var(--white);
        }

        .feed {
            padding: 20px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            flex-grow: 1;
        }

        .item-card {
            background: var(--white);
            border-radius: 20px;
            overflow: hidden;
            border: 1px solid #f1f5f9;
            transition: transform 0.2s;
        }

        .item-card:active {
            transform: scale(0.98);
        }

        .item-image {
            width: 100%;
            height: 150px;
            background: #e2e8f0;
            position: relative;
        }

        .item-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .item-info {
            padding: 12px;
        }

        .item-title {
            font-weight: 600;
            font-size: 0.95rem;
            margin-bottom: 4px;
        }

        .item-location {
            font-size: 0.75rem;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 4px;
        }

        /* --- NAVBAR INFERIOR --- */
        .bottom-nav {
            position: sticky;
            bottom: 0;
            background: var(--white);
            display: flex;
            justify-content: space-around;
            padding: 15px;
            border-top: 1px solid #f1f5f9;
        }

        .nav-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            color: var(--text-muted);
            font-size: 0.7rem;
            cursor: pointer;
        }

        .nav-item.active {
            color: var(--primary);
        }

        .nav-item i {
            font-size: 1.2rem;
        }

        .add-btn {
            background: var(--primary);
            color: white !important;
            width: 45px;
            height: 45px;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            margin-top: -30px;
            box-shadow: 0 10px 20px rgba(16, 185, 129, 0.3);
        }

        /* --- ANIMACIONES --- */
        @keyframes popIn {
            0% { transform: scale(0); opacity: 0; }
            100% { transform: scale(1); opacity: 1; }
        }

        @keyframes fadeInUp {
            from { transform: translateY(20px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .hidden-splash {
            transform: translateY(-100%) !important;
        }

        .show-app {
            opacity: 1 !important;
        }
    </style>
</head>
<body>

    <!-- Pantalla de Splash -->
    <div id="splash-screen">
        <div class="logo-box">
            <i class="fa-solid fa-repeat"></i>
        </div>
        <h1 class="brand-name">Swaply</h1>
        <div class="loader"></div>
    </div>

    <!-- Contenido de la Aplicación -->
    <div id="app-content">
        <header>
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <h2 style="font-weight: 800; font-size: 1.5rem; color: var(--primary);">Swaply</h2>
                <div style="width: 40px; height: 40px; border-radius: 50%; overflow: hidden; background: #e2e8f0;">
                    <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=Felix" alt="Perfil">
                </div>
            </div>
            <div class="search-bar">
                <i class="fa-solid fa-magnifying-glass" style="color: var(--text-muted);"></i>
                <input type="text" placeholder="¿Qué estás buscando?">
            </div>
        </header>

        <div class="categories">
            <div class="category-pill active">Todos</div>
            <div class="category-pill">Tecnología</div>
            <div class="category-pill">Hogar</div>
            <div class="category-pill">Libros</div>
            <div class="category-pill">Ropa</div>
        </div>

        <div class="feed">
            <!-- Item 1 -->
            <div class="item-card">
                <div class="item-image">
                    <img src="http://googleusercontent.com/image_collection/image_retrieval/13936998993859604169" alt="Cámara Vintage">
                </div>
                <div class="item-info">
                    <div class="item-title">Cámara Vintage</div>
                    <div class="item-location"><i class="fa-solid fa-location-dot"></i> a 2km</div>
                </div>
            </div>
            <!-- Item 2 -->
            <div class="item-card">
                <div class="item-image">
                    <img src="http://googleusercontent.com/image_collection/image_retrieval/12967664539655850982" alt="Libro de Arte">
                </div>
                <div class="item-info">
                    <div class="item-title">Libro de Arte</div>
                    <div class="item-location"><i class="fa-solid fa-location-dot"></i> a 500m</div>
                </div>
            </div>
            <!-- Item 3 -->
            <div class="item-card">
                <div class="item-image">
                    <img src="http://googleusercontent.com/image_collection/image_retrieval/12061240173541571477" alt="Planta Monstera">
                </div>
                <div class="item-info">
                    <div class="item-title">Monstera Deliciosa</div>
                    <div class="item-location"><i class="fa-solid fa-location-dot"></i> a 1.2km</div>
                </div>
            </div>
            <!-- Item 4 -->
            <div class="item-card">
                <div class="item-image">
                    <img src="http://googleusercontent.com/image_collection/image_retrieval/1381373977328224749" alt="Cafetera">
                </div>
                <div class="item-info">
                    <div class="item-title">Cafetera Prensa</div>
                    <div class="item-location"><i class="fa-solid fa-location-dot"></i> a 3km</div>
                </div>
            </div>
        </div>

        <nav class="bottom-nav">
            <div class="nav-item active">
                <i class="fa-solid fa-house"></i>
                <span>Inicio</span>
            </div>
            <div class="nav-item">
                <i class="fa-solid fa-heart"></i>
                <span>Deseos</span>
            </div>
            <div class="nav-item add-btn">
                <i class="fa-solid fa-plus"></i>
            </div>
            <div class="nav-item">
                <i class="fa-solid fa-message"></i>
                <span>Chats</span>
            </div>
            <div class="nav-item">
                <i class="fa-solid fa-user"></i>
                <span>Tú</span>
            </div>
        </nav>
    </div>

    <script>
        window.addEventListener('load', () => {
            // Simulamos carga de datos
            setTimeout(() => {
                const splash = document.getElementById('splash-screen');
                const content = document.getElementById('app-content');
                
                splash.classList.add('hidden-splash');
                content.classList.add('show-app');
                
                // Permitimos scroll en el feed
                setTimeout(() => {
                    document.body.style.overflow = 'auto';
                }, 800);
            }, 2500); 
        });
    </script>
</body>
</html>
